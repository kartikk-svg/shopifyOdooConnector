<odoo>
    <record id="view_shopify_instance_tree" model="ir.ui.view">
        <field name="name">shopify.instance.tree</field>
        <field name="model">shopify.instance</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="shop_url"/>
                <field name="company_id"/>
                <field name="warehouse_id"/>
                <field name="active"/>
                <field name="last_product_sync_at"/>
                <field name="last_cart_sync_at"/>
                <field name="last_order_sync_at"/>
            </list>
        </field>
    </record>

    <record id="view_shopify_instance_form" model="ir.ui.view">
        <field name="name">shopify.instance.form</field>
        <field name="model">shopify.instance</field>
        <field name="arch" type="xml">
            <form string="Shopify Instance">
                <header>
                    <button name="action_test_connection" type="object" string="Test Connection" class="btn-primary"/>
                    <button name="action_register_webhooks" type="object" string="Register Webhooks"/>
                    <button name="action_import_products" type="object" string="Import Products"/>
                    <button name="action_import_carts" type="object" string="Import Carts"/>
                    <button name="action_import_orders" type="object" string="Import Orders"/>
                    <button name="action_export_products" type="object" string="Export Products"/>
                    <button name="action_export_inventory" type="object" string="Export Inventory"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="shop_url"/>
                            <field name="api_version"/>
                            <field name="access_token" password="True"/>
                            <field name="webhook_secret" password="True"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                            <field name="warehouse_id"/>
                            <field name="pricelist_id"/>
                            <field name="shopify_location_id"/>
                            <field name="webhook_base_url"/>
                            <field name="webhook_url" readonly="1"/>
                            <field name="local_storefront_base_url"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Automation">
                            <group>
                                <field name="auto_import_products"/>
                                <field name="auto_import_carts"/>
                                <field name="auto_import_orders"/>
                                <field name="auto_export_products"/>
                                <field name="auto_export_inventory"/>
                                <field name="auto_confirm_orders"/>
                                <field name="auto_create_invoice"/>
                                <field name="auto_register_payment"/>
                                <field name="payment_journal_id" invisible="not auto_register_payment"/>
                                <field name="notify_customer_on_fulfillment"/>
                            </group>
                        </page>
                        <page string="Webhook Events">
                            <field name="webhook_event_ids" readonly="1">
                                <list default_order="received_at desc">
                                    <field name="received_at"/>
                                    <field name="topic"/>
                                    <field name="event_type"/>
                                    <field name="status"/>
                                    <field name="order_name"/>
                                    <field name="customer_email"/>
                                    <field name="line_items_count"/>
                                    <field name="variants_count"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="instance_id" readonly="1"/>
                                                <field name="topic" readonly="1"/>
                                                <field name="event_type" readonly="1"/>
                                                <field name="status" readonly="1"/>
                                                <field name="received_at" readonly="1"/>
                                                <field name="processed_at" readonly="1"/>
                                            </group>
                                            <group>
                                                <field name="webhook_id" readonly="1"/>
                                                <field name="shopify_hmac" readonly="1"/>
                                                <field name="shopify_order_id" readonly="1"/>
                                                <field name="order_name" readonly="1"/>
                                                <field name="customer_email" readonly="1"/>
                                                <field name="product_title" readonly="1"/>
                                                <field name="line_items_count" readonly="1"/>
                                                <field name="variants_count" readonly="1"/>
                                            </group>
                                        </group>
                                        <group string="Payload">
                                            <field name="payload_pretty" widget="text" readonly="1"/>
                                        </group>
                                        <group string="Headers">
                                            <field name="headers_json" widget="text" readonly="1"/>
                                        </group>
                                        <group string="Error" invisible="status != 'failed'">
                                            <field name="error_message" widget="text" readonly="1"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Sync Status">
                            <group>
                                <field name="last_product_sync_at" readonly="1"/>
                                <field name="last_cart_sync_at" readonly="1"/>
                                <field name="last_order_sync_at" readonly="1"/>
                                <field name="last_export_sync_at" readonly="1"/>
                                <field name="last_inventory_sync_at" readonly="1"/>
                                <field name="last_webhook_received_at" readonly="1"/>
                            </group>
                            <group string="Webhook Event Metrics">
                                <field name="webhook_event_count" readonly="1"/>
                                <field name="webhook_product_event_count" readonly="1"/>
                                <field name="webhook_cart_event_count" readonly="1"/>
                                <field name="webhook_order_event_count" readonly="1"/>
                                <field name="webhook_failed_event_count" readonly="1"/>
                            </group>
                        </page>
                        <page string="Cart Mappings">
                            <field name="cart_mapping_ids" readonly="1">
                                <list>
                                    <field name="shopify_cart_name"/>
                                    <field name="shopify_cart_id"/>
                                    <field name="shopify_cart_token"/>
                                    <field name="shopify_checkout_token"/>
                                    <field name="odoo_quote_id"/>
                                    <field name="customer_name"/>
                                    <field name="customer_email"/>
                                    <field name="quote_total"/>
                                    <field name="quote_state"/>
                                    <field name="state"/>
                                    <field name="last_synced_at"/>
                                </list>
                            </field>
                        </page>
                        <page string="Product Mappings">
                            <field name="product_mapping_ids" readonly="1">
                                <list>
                                    <field name="product_image" widget="image"/>
                                    <field name="shopify_product_id"/>
                                    <field name="shopify_variant_id"/>
                                    <field name="shopify_inventory_item_id"/>
                                    <field name="odoo_product_id"/>
                                    <field name="sku"/>
                                    <field name="last_synced_at"/>
                                </list>
                            </field>
                        </page>
                        <page string="Order Mappings">
                            <field name="order_mapping_ids" readonly="1">
                                <list>
                                    <field name="shopify_order_name"/>
                                    <field name="shopify_order_id"/>
                                    <field name="odoo_order_id"/>
                                    <field name="customer_name"/>
                                    <field name="customer_email"/>
                                    <field name="order_total"/>
                                    <field name="financial_status"/>
                                    <field name="fulfillment_status"/>
                                    <field name="last_synced_at"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_shopify_instance" model="ir.actions.act_window">
        <field name="name">Shopify Instances</field>
        <field name="res_model">shopify.instance</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_shopify_product_mapping_tree" model="ir.ui.view">
        <field name="name">shopify.product.mapping.tree</field>
        <field name="model">shopify.product.mapping</field>
        <field name="arch" type="xml">
            <list>
                <field name="product_image" widget="image"/>
                <field name="instance_id"/>
                <field name="shopify_product_id"/>
                <field name="shopify_variant_id"/>
                <field name="shopify_inventory_item_id"/>
                <field name="odoo_product_id"/>
                <field name="sku"/>
                <field name="last_synced_at"/>
            </list>
        </field>
    </record>

    <record id="view_shopify_product_mapping_form" model="ir.ui.view">
        <field name="name">shopify.product.mapping.form</field>
        <field name="model">shopify.product.mapping</field>
        <field name="arch" type="xml">
            <form string="Shopify Product Mapping">
                <sheet>
                    <field name="product_image" invisible="1"/>
                    <field name="product_image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'product_image'}"/>
                    <group>
                        <group>
                            <field name="instance_id" readonly="1"/>
                            <field name="shopify_product_id" readonly="1"/>
                            <field name="shopify_variant_id" readonly="1"/>
                            <field name="shopify_inventory_item_id" readonly="1"/>
                            <field name="odoo_product_id" readonly="1"/>
                            <field name="sku" readonly="1"/>
                            <field name="last_synced_at" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shopify_product_mapping" model="ir.actions.act_window">
        <field name="name">Product Mappings</field>
        <field name="res_model">shopify.product.mapping</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_shopify_cart_mapping_tree" model="ir.ui.view">
        <field name="name">shopify.cart.mapping.tree</field>
        <field name="model">shopify.cart.mapping</field>
        <field name="arch" type="xml">
            <list>
                <field name="instance_id"/>
                <field name="shopify_cart_name"/>
                <field name="shopify_cart_id"/>
                <field name="shopify_cart_token"/>
                <field name="shopify_checkout_token"/>
                <field name="odoo_quote_id"/>
                <field name="customer_name"/>
                <field name="customer_email"/>
                <field name="quote_total"/>
                <field name="quote_state"/>
                <field name="state"/>
                <field name="last_synced_at"/>
            </list>
        </field>
    </record>

    <record id="view_shopify_cart_mapping_form" model="ir.ui.view">
        <field name="name">shopify.cart.mapping.form</field>
        <field name="model">shopify.cart.mapping</field>
        <field name="arch" type="xml">
            <form string="Shopify Cart Mapping">
                <sheet>
                    <group>
                        <group>
                            <field name="instance_id" readonly="1"/>
                            <field name="shopify_cart_name" readonly="1"/>
                            <field name="shopify_cart_id" readonly="1"/>
                            <field name="shopify_cart_token" readonly="1"/>
                            <field name="shopify_checkout_token" readonly="1"/>
                            <field name="odoo_quote_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="state" readonly="1"/>
                            <field name="quote_state" readonly="1"/>
                            <field name="quote_total" readonly="1"/>
                            <field name="last_synced_at" readonly="1"/>
                        </group>
                    </group>
                    <group string="Customer Details">
                        <field name="customer_name" readonly="1"/>
                        <field name="customer_email" readonly="1"/>
                        <field name="customer_phone" readonly="1"/>
                    </group>
                    <group string="Cart Products">
                        <field name="quote_line_ids" readonly="1">
                            <list>
                                <field name="product_id" widget="image" options="{'preview_image': 'image_128', 'size': [45, 45]}" nolabel="1" width="60"/>
                                <field name="product_id"/>
                                <field name="name"/>
                                <field name="product_uom_qty"/>
                                <field name="price_unit"/>
                                <field name="price_subtotal"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shopify_cart_mapping" model="ir.actions.act_window">
        <field name="name">Cart Mappings</field>
        <field name="res_model">shopify.cart.mapping</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_shopify_order_mapping_tree" model="ir.ui.view">
        <field name="name">shopify.order.mapping.tree</field>
        <field name="model">shopify.order.mapping</field>
        <field name="arch" type="xml">
            <list>
                <field name="instance_id"/>
                <field name="shopify_order_name"/>
                <field name="shopify_order_id"/>
                <field name="odoo_order_id"/>
                <field name="customer_name"/>
                <field name="customer_email"/>
                <field name="order_total"/>
                <field name="financial_status"/>
                <field name="fulfillment_status"/>
                <field name="last_synced_at"/>
            </list>
        </field>
    </record>

    <record id="view_shopify_order_mapping_form" model="ir.ui.view">
        <field name="name">shopify.order.mapping.form</field>
        <field name="model">shopify.order.mapping</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Shopify Order Mapping">
                <header>
                    <button name="action_print_order" type="object" string="Print Order (PDF)" class="btn-primary"/>
                    <button name="action_download_invoice" type="object" string="Download Invoice"/>
                </header>
                <sheet>
                    <field name="has_posted_invoice" invisible="1"/>
                    <group>
                        <group>
                            <field name="instance_id" readonly="1"/>
                            <field name="shopify_order_name" readonly="1"/>
                            <field name="shopify_order_id" readonly="1"/>
                            <field name="odoo_order_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="financial_status" readonly="1"/>
                            <field name="fulfillment_status" readonly="1"/>
                            <field name="last_synced_at" readonly="1"/>
                            <field name="order_total" readonly="1"/>
                        </group>
                    </group>
                    <group string="Customer Details">
                        <field name="customer_name" readonly="1"/>
                        <field name="customer_email" readonly="1"/>
                        <field name="customer_phone" readonly="1"/>
                        <field name="customer_address" readonly="1"/>
                    </group>
                    <group string="Ordered Products">
                        <field name="order_line_ids" readonly="1">
                            <list>
                                <field name="product_id" widget="image" options="{'preview_image': 'image_128', 'size': [45, 45]}" nolabel="1" width="60"/>
                                <field name="product_id"/>
                                <field name="name"/>
                                <field name="product_uom_qty"/>
                                <field name="price_unit"/>
                                <field name="price_subtotal"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shopify_order_mapping" model="ir.actions.act_window">
        <field name="name">Order Mappings</field>
        <field name="res_model">shopify.order.mapping</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_shopify_webhook_event_tree" model="ir.ui.view">
        <field name="name">shopify.webhook.event.tree</field>
        <field name="model">shopify.webhook.event</field>
        <field name="arch" type="xml">
            <list default_order="received_at desc">
                <field name="received_at"/>
                <field name="instance_id"/>
                <field name="topic"/>
                <field name="event_type"/>
                <field name="status"/>
                <field name="order_name"/>
                <field name="customer_email"/>
                <field name="line_items_count"/>
                <field name="variants_count"/>
            </list>
        </field>
    </record>

    <record id="view_shopify_webhook_event_form" model="ir.ui.view">
        <field name="name">shopify.webhook.event.form</field>
        <field name="model">shopify.webhook.event</field>
        <field name="arch" type="xml">
            <form string="Webhook Event">
                <sheet>
                    <group>
                        <group>
                            <field name="instance_id" readonly="1"/>
                            <field name="topic" readonly="1"/>
                            <field name="event_type" readonly="1"/>
                            <field name="status" readonly="1"/>
                            <field name="received_at" readonly="1"/>
                            <field name="processed_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="webhook_id" readonly="1"/>
                            <field name="shopify_hmac" readonly="1"/>
                            <field name="shopify_order_id" readonly="1"/>
                            <field name="order_name" readonly="1"/>
                            <field name="customer_email" readonly="1"/>
                            <field name="product_title" readonly="1"/>
                            <field name="line_items_count" readonly="1"/>
                            <field name="variants_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Payload">
                        <field name="payload_pretty" widget="text" readonly="1"/>
                    </group>
                    <group string="Headers">
                        <field name="headers_json" widget="text" readonly="1"/>
                    </group>
                    <group string="Error" invisible="status != 'failed'">
                        <field name="error_message" widget="text" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shopify_webhook_event" model="ir.actions.act_window">
        <field name="name">Webhook Events</field>
        <field name="res_model">shopify.webhook.event</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
